# Application environment: base | production
APP_ENV=base

# Database URL (required in production)
# SQLite (development)
DATABASE_URL=sqlite:///./classifier.db
# Postgres (production example)
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/finguard

# Checkpointer backend: auto | in-memory | sqlite | postgres
CHECKPOINTER_BACKEND=auto
