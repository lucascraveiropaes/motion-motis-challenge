set windows-shell := ["powershell.exe", "-NoProfile", "-Command"]

# Sync all dependencies across the workspace
install:
    uv sync --all-packages --group dev

# Format and lint (Ruff)
lint:
    uv run ruff check .
    uv run ruff format . --check

# Type checking with mypy
typecheck:
    uv run mypy .

# Run tests with coverage
test:
    uv run pytest application-agents/classifier-agent -vv --cov=classifier_agent --cov=transaction_engine

# Start the classifier agent in development mode
dev:
    uv run fastapi dev application-agents/classifier-agent/src/classifier_agent/app.py --port 8080

# Start with a custom port
dev-port port:
    uv run fastapi dev application-agents/classifier-agent/src/classifier_agent/app.py --port {{port}}

# Helper to create a new shared package
new-package name:
    mkdir -p packages/{{name}}
    cd packages/{{name}} && uv init --lib

# Helper to create a new agent
new-agent name:
    mkdir -p application-agents/{{name}}
    cd application-agents/{{name}} && uv init --app
